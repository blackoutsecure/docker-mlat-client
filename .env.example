# Timezone configuration
TZ=Etc/UTC

# mlat-client runtime user (root is default)
MLAT_CLIENT_USER=root

# User and Group IDs (optional, used with non-root MLAT_CLIENT_USER)
# PUID=911
# PGID=911

# File mask (default: 022, use 002 for group-writable files)
UMASK=022

# Beast data source (host:port of readsb/dump1090 beast output)
MLAT_CLIENT_INPUT_CONNECT=readsb:30005

# Multilateration server address (host:port)
MLAT_CLIENT_SERVER=feed.adsbexchange.com:31090

# Receiver location (REQUIRED)
MLAT_CLIENT_LAT=0.0
MLAT_CLIENT_LON=0.0
MLAT_CLIENT_ALT=0m

# User identifier for the MLAT server (REQUIRED)
MLAT_CLIENT_USER_ID=changeme

# Results output destination
# Examples:
#   beast,connect,readsb:30104
#   beast,listen,30105
#   basestation,listen,31003
MLAT_CLIENT_RESULTS=beast,connect,readsb:30104

# UUID (optional, path to file or value)
# MLAT_CLIENT_UUID_FILE=/config/mlat-client/uuid
# MLAT_CLIENT_UUID=

# Statistics JSON output path (optional)
# MLAT_CLIENT_STATS_JSON=/config/mlat-client/stats.json

# Privacy mode (hides receiver pin on coverage maps)
# MLAT_CLIENT_PRIVACY=false

# Disable UDP transport
# MLAT_CLIENT_NO_UDP=false

# Enable log timestamps (default: true)
MLAT_CLIENT_LOG_TIMESTAMPS=true

# Or pass raw arguments directly (overrides individual env vars above)
# MLAT_CLIENT_ARGS=--input-connect readsb:30005 --server feed.adsbexchange.com:31090 --lat 51.5 --lon -0.1 --alt 50m --user myuser

# Container restart policy
RESTART_POLICY=unless-stopped

# Docker Compose service name
COMPOSE_SERVICE_NAME=mlat-client
COMPOSE_PROJECT_NAME=mlat-client
