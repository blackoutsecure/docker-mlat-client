#!/usr/bin/with-contenv bash

set -euo pipefail

# ── Logging ───────────────────────────────────────────────────────────────────
SVC_NAME="svc-mlat-client"
# shellcheck source=/usr/local/bin/log-functions.sh
. /usr/local/bin/log-functions.sh

mlat_client_user=${MLAT_CLIENT_USER:-root}
build_metadata_path=/usr/local/share/mlat-client/build-metadata.env

# ── Restart backoff ───────────────────────────────────────────────────────────
# Prevent tight crash loops when the MLAT server or input source is unavailable.
# Track consecutive failures via an ephemeral file in /run and apply a
# progressive delay (5s → 10s → 15s … max 60s) before each attempt.
#
# Note: the fail counter is pre-incremented BEFORE exec (since exec replaces
# the process and EXIT traps never fire). We must assume failure upfront.
# If the previous run lasted ≥ _MIN_HEALTHY_SECS, it was not a crash loop
# and the counter is reset to avoid false-positive warnings.
_fail_count_file="/run/mlat-client-fail-count"
_start_ts_file="/run/mlat-client-start-ts"
_MIN_HEALTHY_SECS=60
_fail_count=0
if [[ -f "${_fail_count_file}" ]]; then
    _fail_count=$(tr -d '[:space:]' < "${_fail_count_file}")
    _fail_count=${_fail_count:-0}
fi
# Reset fail counter if the previous run was long-lived (not a crash loop)
if [[ ${_fail_count} -gt 0 && -f "${_start_ts_file}" ]]; then
    _prev_start=$(tr -d '[:space:]' < "${_start_ts_file}")
    _now=$(date +%s)
    if [[ -n "${_prev_start}" ]] && (( _now - _prev_start >= _MIN_HEALTHY_SECS )); then
        log_info "Previous run lasted $(( _now - _prev_start ))s (≥${_MIN_HEALTHY_SECS}s). Resetting fail counter."
        _fail_count=0
        rm -f "${_fail_count_file}"
    fi
fi
_is_restart=false
if [[ ${_fail_count} -gt 0 ]]; then
    _is_restart=true
    _backoff=$(( _fail_count * 5 ))
    [[ ${_backoff} -gt 60 ]] && _backoff=60
    log_warn "Previous launch failed (attempt #${_fail_count}). Waiting ${_backoff}s before retry."
    sleep "${_backoff}"
fi

# Import build metadata captured from upstream mlat-client so these values are
# available to the service process in production.
if [[ -r "${build_metadata_path}" ]]; then
    set -a
    # shellcheck disable=SC1090
    . "${build_metadata_path}"
    set +a
fi

if [[ "${mlat_client_user}" != "root" ]]; then
    if [[ "${mlat_client_user}" == "abc" && -z ${PUID:-} ]]; then
        export PUID=911
    fi
    if [[ "${mlat_client_user}" == "abc" && -z ${PGID:-} ]]; then
        export PGID=911
    fi
fi

# Build effective mlat-client arguments
mlat_client_args=()
mlat_client_args_source="default"

if [[ -n ${MLAT_CLIENT_ARGS:-} ]]; then
    mlat_client_args_source="env"
    read -r -a mlat_client_args <<< "${MLAT_CLIENT_ARGS}"
fi

# Append required arguments from individual env vars if not already in MLAT_CLIENT_ARGS
has_mlat_opt() {
    local opt=$1
    local token
    for token in "${mlat_client_args[@]}"; do
        if [[ ${token} == "${opt}" || ${token} == "${opt}="* ]]; then
            return 0
        fi
    done
    return 1
}

# --input-connect (Beast data source)
if [[ -n ${MLAT_CLIENT_INPUT_CONNECT:-} ]] && ! has_mlat_opt "--input-connect"; then
    mlat_client_args+=(--input-connect "${MLAT_CLIENT_INPUT_CONNECT}")
fi

# --server (multilateration server)
if [[ -n ${MLAT_CLIENT_SERVER:-} ]] && ! has_mlat_opt "--server"; then
    mlat_client_args+=(--server "${MLAT_CLIENT_SERVER}")
fi

# --lat (receiver latitude)
if [[ -n ${MLAT_CLIENT_LAT:-} ]] && ! has_mlat_opt "--lat"; then
    mlat_client_args+=(--lat "${MLAT_CLIENT_LAT}")
fi

# --lon (receiver longitude)
if [[ -n ${MLAT_CLIENT_LON:-} ]] && ! has_mlat_opt "--lon"; then
    mlat_client_args+=(--lon "${MLAT_CLIENT_LON}")
fi

# --alt (receiver altitude)
if [[ -n ${MLAT_CLIENT_ALT:-} ]] && ! has_mlat_opt "--alt"; then
    mlat_client_args+=(--alt "${MLAT_CLIENT_ALT}")
fi

# --user (user identifier)
if [[ -n ${MLAT_CLIENT_USER_ID:-} ]] && ! has_mlat_opt "--user"; then
    mlat_client_args+=(--user "${MLAT_CLIENT_USER_ID}")
fi

# --results (output mode/destination)
if [[ -n ${MLAT_CLIENT_RESULTS:-} ]] && ! has_mlat_opt "--results"; then
    mlat_client_args+=(--results "${MLAT_CLIENT_RESULTS}")
fi

# --uuid-file (default: /config/feed-uuid-adsbexchange)
mlat_client_uuid_file=${MLAT_CLIENT_UUID_FILE:-/config/feed-uuid-adsbexchange}
mlat_client_uuid_value=""
if [[ -n ${mlat_client_uuid_file} ]] && ! has_mlat_opt "--uuid-file"; then
    if [[ -r "${mlat_client_uuid_file}" ]]; then
        mlat_client_args+=(--uuid-file "${mlat_client_uuid_file}")
        mlat_client_uuid_value=$(tr -d '[:space:]' < "${mlat_client_uuid_file}")
    else
        log_warn "UUID file not found: ${mlat_client_uuid_file}"
    fi
fi

# --uuid (inline value overrides file)
if [[ -n ${MLAT_CLIENT_UUID:-} ]] && ! has_mlat_opt "--uuid"; then
    mlat_client_args+=(--uuid "${MLAT_CLIENT_UUID}")
    mlat_client_uuid_value="${MLAT_CLIENT_UUID}"
fi

# --stats-json
if [[ -n ${MLAT_CLIENT_STATS_JSON:-} ]] && ! has_mlat_opt "--stats-json"; then
    mlat_client_args+=(--stats-json "${MLAT_CLIENT_STATS_JSON}")
fi

# --no-udp
if [[ ${MLAT_CLIENT_NO_UDP:-false} == "true" ]] && ! has_mlat_opt "--no-udp"; then
    mlat_client_args+=(--no-udp)
fi

# --privacy
if [[ ${MLAT_CLIENT_PRIVACY:-false} == "true" ]] && ! has_mlat_opt "--privacy"; then
    mlat_client_args+=(--privacy)
fi

# --log-timestamps
if [[ ${MLAT_CLIENT_LOG_TIMESTAMPS:-true} == "true" ]] && ! has_mlat_opt "--log-timestamps"; then
    mlat_client_args+=(--log-timestamps)
fi

mlat_client_args_rendered=$(printf '%q ' "${mlat_client_args[@]}")
mlat_client_args_rendered=${mlat_client_args_rendered% }

build_version=${VERSION:-unknown}
if [[ -r /build_version ]]; then
    build_version=$(< /build_version)
fi

# Wait for Beast data source to be available before starting
input_host="${MLAT_CLIENT_INPUT_CONNECT%%:*}"
input_port="${MLAT_CLIENT_INPUT_CONNECT##*:}"
if [[ -n "${input_host}" && -n "${input_port}" ]]; then
    log_info "waiting for ${input_host}:${input_port} to be available..."
    retries=0
    max_retries=60
    while ! echo > "/dev/tcp/${input_host}/${input_port}" 2>/dev/null; do
        retries=$((retries + 1))
        if (( retries >= max_retries )); then
            log_warn "${input_host}:${input_port} not reachable after ${max_retries} attempts, starting anyway"
            break
        fi
        sleep 2
    done
    if (( retries < max_retries )); then
        log_info "${input_host}:${input_port} is reachable (after ${retries} checks)"
    fi
fi

# On restarts, log a compact summary instead of the full config dump.
if [[ "${_is_restart}" == "true" ]]; then
    log_info "mlat-client restarting (attempt #$((_fail_count + 1))). effective_ARGS: ${mlat_client_args_rendered}"
else
    log_info "mlat-client multilateration service starting"
    log_kv "build_version" "${build_version}"
    log_kv "VERSION" "${VERSION:-unknown}"
    log_kv "BUILD_DATE" "${BUILD_DATE:-unknown}"
    log_kv "VCS_REF" "${VCS_REF:-unknown}"
    log_kv "PUID" "${PUID:-unset}"
    log_kv "PGID" "${PGID:-unset}"
    log_kv "TZ" "${TZ:-unset}"
    log_kv "MLAT_CLIENT_USER" "${mlat_client_user}"
    log_kv "input-connect" "${MLAT_CLIENT_INPUT_CONNECT:-unset}"
    log_kv "server" "${MLAT_CLIENT_SERVER:-unset}"
    log_kv "lat" "${MLAT_CLIENT_LAT:-unset}"
    log_kv "lon" "${MLAT_CLIENT_LON:-unset}"
    log_kv "alt" "${MLAT_CLIENT_ALT:-unset}"
    log_kv "user-id" "${MLAT_CLIENT_USER_ID:-unset}"
    log_kv "uuid" "${mlat_client_uuid_value:-unset}"
    log_kv "uuid-file" "${mlat_client_uuid_file:-unset}"
    log_kv "AUTO_LOCATION" "${MLAT_CLIENT_AUTO_LOCATION:-true}"
    log_kv "ARGS(src)" "${mlat_client_args_source}"
    log_kv "effective_ARGS" "${mlat_client_args_rendered}"
fi

# Validate required arguments
missing_args=()
if ! has_mlat_opt "--lat"; then
    missing_args+=("--lat (set MLAT_CLIENT_LAT)")
fi
if ! has_mlat_opt "--lon"; then
    missing_args+=("--lon (set MLAT_CLIENT_LON)")
fi
if ! has_mlat_opt "--alt"; then
    missing_args+=("--alt (set MLAT_CLIENT_ALT)")
fi
if ! has_mlat_opt "--user"; then
    missing_args+=("--user (set MLAT_CLIENT_USER_ID)")
fi

if [[ ${#missing_args[@]} -gt 0 ]]; then
    log_error "required arguments missing:"
    for arg in "${missing_args[@]}"; do
        log_error "  - ${arg}"
    done
    log_error "set the required environment variables and restart"
    sleep 30
    exit 1
fi

# Pre-increment the fail counter BEFORE exec.  exec replaces this process so
# EXIT traps never fire — we must assume failure upfront.
echo "$(( _fail_count + 1 ))" > "${_fail_count_file}"

# Record start timestamp so the next invocation can distinguish a crash loop
# (short-lived) from a healthy run that simply exited normally.
date +%s > "${_start_ts_file}"

if [[ -z ${LSIO_NON_ROOT_USER:-} ]]; then
    exec s6-setuidgid "${mlat_client_user}" /usr/local/bin/mlat-client \
        "${mlat_client_args[@]}"
fi

exec /usr/local/bin/mlat-client "${mlat_client_args[@]}"
